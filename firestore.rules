rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    // Equipment inventory: only signed-in tech support admins can read/write.
    match /equipment/{equipmentId} {
      allow read, write: if isSignedIn();
    }

    // Borrow requests: the public can create a request (the borrower's form),
    // but only admins can read the list, update it (scanning/finalizing/returning),
    // or delete it. This keeps other borrowers' names/contact numbers private.
    match /borrowRequests/{requestId} {
      allow create: if request.resource.data.keys().hasAll(
        ['name', 'ministry', 'contactNo', 'venue', 'equipmentRequested', 'status', 'items', 'submittedAt']
      ) && request.resource.data.status == 'pending'
        && request.resource.data.items.size() == 0;
      allow read, update, delete: if isSignedIn();
    }
  }
}
